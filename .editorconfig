# SPDX-License-Identifier: MIT
# EditorConfig — https://editorconfig.org

root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 100

[*.{js,ts,jsx,tsx,json,html,css,svelte,vue}]
indent_size = 2

[*.{md,rst}]
trim_trailing_whitespace = false
max_line_length = off

[Makefile]
indent_style = tab

[*.{yml,yaml,toml}]
indent_size = 2

[*.rs]
indent_size = 4
max_line_length = 100
